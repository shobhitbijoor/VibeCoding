# ============================================
# KUZU GRAPH DATABASE COPILOT - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your API keys
# You only need ONE of these API keys based on which LLM provider you want to use

# ============================================
# OPTION 1: OpenAI (Recommended for beginners)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
# Models: gpt-4o-mini, gpt-4o, gpt-4-turbo
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# OPTION 2: Anthropic (Claude)
# ============================================
# Get your API key from: https://console.anthropic.com/settings/keys
# Models: claude-3-5-sonnet-latest, claude-3-5-haiku-latest
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================
# OPTION 3: Google AI (Gemini)
# ============================================
# Get your API key from: https://aistudio.google.com/app/apikey
# Models: gemini-1.5-flash, gemini-1.5-pro
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key-here

# ============================================
# NOTES
# ============================================
# - You only need ONE API key from any provider
# - The Copilot will automatically use the key for the selected model
# - If you don't set environment variables, you can enter the API key
#   directly in the Copilot Settings panel (API Key tab)
# - API keys entered in the UI are only stored in browser memory for
#   the current session and are not persisted

# ============================================
# PRICING REFERENCE (as of 2024)
# ============================================
# OpenAI:
#   - GPT-4o Mini: ~$0.15/1M input, $0.60/1M output (cheapest)
#   - GPT-4o: ~$2.50/1M input, $10/1M output
#
# Anthropic:
#   - Claude 3.5 Haiku: ~$0.25/1M input, $1.25/1M output
#   - Claude 3.5 Sonnet: ~$3/1M input, $15/1M output
#
# Google:
#   - Gemini 1.5 Flash: ~$0.075/1M input, $0.30/1M output (cheapest)
#   - Gemini 1.5 Pro: ~$1.25/1M input, $5/1M output
