# ============================================
# KUZU GRAPH DATABASE COPILOT - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your API keys
# You only need ONE of these API keys based on which LLM provider you want to use

# ============================================
# OPTION 1: Azure CoE (Center of Excellence)
# ============================================
# Azure OpenAI GPT-4o via Center of Excellence deployment
AZURE_COE_ENDPOINT=https://mfg-nag-openai-models.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
AZURE_COE_API_KEY=AxwS27jCeRmTqfe4yLMwAXxH22hGrTrRsToIWivgjvQiJZRQ2xHxJQQJ99CDACYeBjFXJ3w3AAABACOGfgQn

# ============================================
# OPTION 2: OpenAI (Recommended for beginners)
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
# Models: gpt-4o-mini, gpt-4o, gpt-4-turbo
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# OPTION 2: Anthropic (Claude)
# ============================================
# Get your API key from: https://console.anthropic.com/settings/keys
# Models: claude-3-5-sonnet-latest, claude-3-5-haiku-latest
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================
# OPTION 3: Google AI (Gemini)
# ============================================
# Get your API key from: https://aistudio.google.com/app/apikey
# Models: gemini-3-flash, gemini-3-pro-preview, gemini-3.1-flash-lite, gemini-3.1-pro-preview
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyClpicxV9_5ndHfjdjxP5-NPpxDhA2a7Qo

# ============================================
# OPTION 4: Hugging Face (Free Open Source Models)
# ============================================
# Get your free API key from: https://huggingface.co/settings/tokens
# Free tier includes daily credits for inference
# Models: Mistral-7B-Instruct-v0.3, Llama-3.2-3B-Instruct
HUGGINGFACE_API_KEY=hf_your-huggingface-api-key-here

# ============================================
# NOTES
# ============================================
# - You only need ONE API key from any provider
# - The Copilot will automatically use the key for the selected model
# - If you don't set environment variables, you can enter the API key
#   directly in the Copilot Settings panel (API Key tab)
# - API keys entered in the UI are only stored in browser memory for
#   the current session and are not persisted

# ============================================
# PRICING REFERENCE (as of 2024)
# ============================================
# OpenAI:
#   - GPT-4o Mini: ~$0.15/1M input, $0.60/1M output (cheapest)
#   - GPT-4o: ~$2.50/1M input, $10/1M output
#
# Anthropic:
#   - Claude 3.5 Haiku: ~$0.25/1M input, $1.25/1M output
#   - Claude 3.5 Sonnet: ~$3/1M input, $15/1M output
#
# Google:
#   - Gemini 3 Flash: ~$0.10/1M input, $0.40/1M output (fast & affordable)
#   - Gemini 3 Pro: ~$1.25/1M input, $5/1M output
#   - Gemini 3.1 Flash Lite: ~$0.075/1M input, $0.30/1M output (cheapest)
#   - Gemini 3.1 Pro: ~$2.50/1M input, $10/1M output
#
# Hugging Face (Free Tier):
#   - Mistral 7B Instruct: FREE (daily credits)
#   - Llama 3.2 3B Instruct: FREE (daily credits)
#   - Note: Free tier has rate limits; upgrade for higher throughput
